# Palmtop environment variables
# Copy to .env and fill in the values you need.
# All variables are optional — only set what you use.
#
# ── Secrets Management (recommended: dotenvx) ────────────────────────
# dotenvx encrypts your .env so secrets can be safely committed to git.
#
#   1. Install:    brew install dotenvx/brew/dotenvx  (or: npx @dotenvx/dotenvx)
#   2. Copy:       cp .env.example .env && $EDITOR .env
#   3. Encrypt:    dotenvx encrypt
#   4. Run:        dotenvx run -- python -m palmtop
#   5. Commit:     git add .env.vault .env.keys  (keys stay local or in CI secrets)
#
# Or use `palmtop init` to do steps 1-3 interactively.
# See: https://dotenvx.com/docs

# ── LLM Providers ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # Claude (heavy tier)
GOOGLE_API_KEY=              # Gemini (light tier + STT)
OPENAI_API_KEY=              # Whisper STT (optional)

# ── Channels ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # From @BotFather

# ── Email ─────────────────────────────────────────────────────────
AGENTMAIL_API_KEY=           # agentmail.to API key
AGENTMAIL_INBOX_ID=          # Inbox ID for receiving

# ── Web Search ────────────────────────────────────────────────────
BRAVE_API_KEY=               # Brave Search (primary)
SERPER_API_KEY=              # Serper.dev (fallback)

# ── Atlassian ─────────────────────────────────────────────────────
JIRA_API_TOKEN=
CONFLUENCE_API_TOKEN=
# Domain and email are set in config.toml [atlassian] section

# ── Deploy ────────────────────────────────────────────────────────
VERCEL_TOKEN=
RAILWAY_TOKEN=

# ── Cursor Cloud Agents ───────────────────────────────────────────
CURSOR_API_KEY=

# ── Local Inference ───────────────────────────────────────────────
# MODEL_PATH=./models/your-model.gguf
# WHISPER_MODEL_PATH=./models/whisper.bin

# ── Safety floor (guardrail integrity) ────────────────────────────
# Minimum guardrail policy enforced at startup. These come from the process
# environment ON PURPOSE — the agent's own tools can't set the env of a process
# it doesn't launch, so it can't disable its own guardrails by writing config.
# Effective config is CLAMPED up to this floor; below-floor launches are audited.
#
# PALMTOP_FLOOR_REQUIRE_BLESSING=1     # default 1: *.require_blessing can't be disabled
# PALMTOP_FLOOR_REQUIRE_ALIGNMENT=0    # set 1 to force [alignment] mode = "hard"
# PALMTOP_FLOOR_NO_PUBLIC_CHANNELS=0   # set 1 to forbid channel allow_anyone = true
# PALMTOP_ALLOW_AUTONOMOUS=0           # set 1 to permit --autonomous / PALMTOP_AUTONOMOUS
# PALMTOP_ALLOW_UNSAFE=0               # operator escape hatch: run BELOW the floor (audited)

# ── Backup encryption (data-at-rest) ──────────────────────────────
# When set, `palmtop backup` / `export` encrypt their output (and restore /
# import decrypt it). Backups leave the device's storage encryption, so this
# protects them. Needs the cryptography package: uv sync --extra encryption
# (or `pkg install python-cryptography` on Termux). Use a long random value —
# and keep it safe: lose the key and encrypted backups are unrecoverable.
# PALMTOP_DB_KEY=
